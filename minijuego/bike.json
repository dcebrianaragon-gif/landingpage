{
  "name": "Bike",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Bike manufacturer name"
    },
    "flag": {
      "type": "string",
      "description": "Country flag emoji"
    },
    "info": {
      "type": "string",
      "description": "Short description of the bike"
    },
    "max_speed": {
      "type": "number",
      "description": "Maximum speed factor",
      "default": 2.3
    },
    "accel": {
      "type": "number",
      "description": "Acceleration factor",
      "default": 0.033
    },
    "brake": {
      "type": "number",
      "description": "Braking factor",
      "default": 0.065
    },
    "turn": {
      "type": "number",
      "description": "Turn rate factor",
      "default": 0.045
    },
    "lean": {
      "type": "number",
      "description": "Lean interpolation factor",
      "default": 0.14
    },
    "top_gear": {
      "type": "number",
      "description": "Number of gears",
      "default": 6
    },
    "color_hex": {
      "type": "string",
      "description": "Hex color code without # (e.g. e10000)",
      "default": "e10000"
    }
  },
  "required": [
    "name"
  ]
}